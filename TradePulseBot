    'secret': os.getenv('BINANCE_SECRET'),
    'enableRateLimit': True,
    'options': {'defaultType': 'spot'},
    # testnet لو تبي تجرب بدون مخاطر:
    # 'urls': {'api': 'https://testnet.binance.vision/api'}
})

