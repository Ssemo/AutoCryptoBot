import ccxt
import time
from dotenv import load_dotenv
import os

# قراءة المفاتيح
load_dotenv()

# إعداد البورصة (ديمو/تستنت)
exchange = ccxt.binance({
    'apiKey': os.getenv('BINANCE_API_KEY'),
    'secret': os.getenv('BINANCE_SECRET'),
    'enableRateLimit': True,
    'options': {'defaultType': 'spot'},
})

# الخطوة المهمة: فعّل الديمو (يغير الـ endpoint تلقائيًا)
exchange.enable_demo_trading(True)

print("البوت بدأ... 🚀")

symbol = 'SOL/USDT'
buy_threshold = 140.0
sell_threshold = 150.0
amount = 0.1  # كمية صغيرة للتجربة

while True:
    try:
        # جيب السعر
        ticker = exchange.fetch_ticker(symbol)
        price = float(ticker )
        print(f"سعر {symbol} الحالي: ${price:.2f}")

        # جيب الرصيد
        balance = exchange.fetch_balance()
        usdt_free = balance.get('USDT', {}).get('free', 0)
        sol_free = balance.get('SOL', {}).get('free', 0)
        print(f"USDT متاح: {usdt_free:.2f} | SOL متاح: {sol_free:.4f}")

        # منطق الشراء
        if price <= buy_threshold and usdt_free >= amount * price:
            print("→ تحت سعر الشراء! بنشتري...")
            # exchange.create_market_buy_order(symbol, amount)  # شيل # للتفعيل

        # منطق البيع
        elif price >= sell_threshold and sol_free >= amount:
            print("→ فوق سعر البيع! بنبيع...")
            # exchange.create_market_sell_order(symbol, amount)  # شيل # للتفعيل

        time.sleep(10)  # انتظر 10 ثواني

    except Exception as e:
        print(f"خطأ: {str(e)}")
        time.sleep(30)